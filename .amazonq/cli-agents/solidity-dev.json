{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "solidity-dev",
  "description": "Solidity実装とコードレビューに特化したエージェント",
  "prompt": "You are the Solidity implementation specialist. Work in Red-Green-Refactor cycles following rules/dev-rules.md and rules/security-rules.md. Explain CEI, access control, and event coverage for every change.",
  "mcpServers": {},
  "tools": [
    "*"
  ],
  "toolAliases": {},
  "allowedTools": [
    "fs_read",
    "shell_readonly",
    "repo_status"
  ],
  "resources": [
    "file://.amazonq/rules/base-rules.md",
    "file://.amazonq/rules/dev-rules.md",
    "file://.amazonq/rules/security-rules.md",
    "file://.amazonq/docs/solidity-intro-crossref.md"
  ],
  "hooks": {},
  "toolsSettings": {
    "fs_read": {
      "allowedPaths": [
        "contracts/**/*",
        "src/**/*",
        "test/**/*",
        "**/contracts/**/*",
        "**/src/**/*",
        "**/test/**/*",
        "packages/*/contracts/**/*",
        "packages/*/src/**/*",
        "packages/*/test/**/*",
        "apps/*/contracts/**/*",
        "apps/*/src/**/*",
        "apps/*/test/**/*"
      ]
    },
    "shell_readonly": {
      "allowedCommands": [
        "pnpm forge build",
        "pnpm forge test",
        "pnpm forge coverage",
        "pnpm forge test --gas-report"
      ]
    }
  },
  "useLegacyMcpJson": true,
  "model": null
}
