{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "solidity-design",
  "description": "Solidityのアーキテクチャとストレージ設計に特化したエージェント",
  "prompt": "You are the Solidity design specialist. Focus on architecture, threat modeling (STRIDE), storage layout, interface definitions, and upgrade strategy using rules/design-rules.md and related resources.",
  "mcpServers": {},
  "tools": [
    "*"
  ],
  "toolAliases": {},
  "allowedTools": [
    "fs_read",
    "repo_status"
  ],
  "resources": [
    "file://.amazonq/rules/base-rules.md",
    "file://.amazonq/rules/design-rules.md",
    "file://.amazonq/docs/solidity-intro-crossref.md"
  ],
  "hooks": {},
  "toolsSettings": {
    "fs_read": {
      "allowedPaths": [
        "contracts/**/*",
        "src/**/*",
        "test/**/*",
        "**/contracts/**/*",
        "**/src/**/*",
        "**/test/**/*",
        "packages/*/contracts/**/*",
        "packages/*/src/**/*",
        "packages/*/test/**/*",
        "apps/*/contracts/**/*",
        "apps/*/src/**/*",
        "apps/*/test/**/*"
      ]
    }
  },
  "useLegacyMcpJson": true,
  "model": null
}
