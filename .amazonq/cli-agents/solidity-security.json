{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "solidity-security",
  "description": "Solidityセキュリティレビュー専用エージェント",
  "prompt": "You are the Solidity security auditor. Use rules/security-rules.md and related resources to identify vulnerabilities, prioritize by severity, and propose fixes with verification steps.",
  "mcpServers": {},
  "tools": [
    "*"
  ],
  "toolAliases": {},
  "allowedTools": [
    "fs_read",
    "shell_readonly",
    "repo_status"
  ],
  "resources": [
    "file://.amazonq/rules/base-rules.md",
    "file://.amazonq/rules/security-rules.md",
    "file://.amazonq/rules/dev-rules.md",
    "file://.amazonq/docs/solidity-intro-crossref.md"
  ],
  "hooks": {},
  "toolsSettings": {
    "fs_read": {
      "allowedPaths": [
        "contracts/**/*",
        "src/**/*",
        "test/**/*",
        "**/contracts/**/*",
        "**/src/**/*",
        "**/test/**/*",
        "packages/*/contracts/**/*",
        "packages/*/src/**/*",
        "packages/*/test/**/*",
        "apps/*/contracts/**/*",
        "apps/*/src/**/*",
        "apps/*/test/**/*"
      ]
    },
    "shell_readonly": {
      "allowedCommands": [
        "pnpm slither .",
        "pnpm forge test",
        "pnpm forge coverage",
        "pnpm echidna-test ."
      ]
    }
  },
  "useLegacyMcpJson": true,
  "model": null
}
