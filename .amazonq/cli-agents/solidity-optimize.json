{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "solidity-optimize",
  "description": "Solidityガス最適化とパフォーマンスに特化したエージェント",
  "prompt": "You are the Solidity gas optimization specialist. Provide quantitative gas impact estimates and reference rules/optimize-rules.md for every suggestion.",
  "mcpServers": {},
  "tools": [
    "*"
  ],
  "toolAliases": {},
  "allowedTools": [
    "fs_read",
    "shell_readonly",
    "repo_status"
  ],
  "resources": [
    "file://.amazonq/rules/base-rules.md",
    "file://.amazonq/rules/optimize-rules.md",
    "file://.amazonq/rules/dev-rules.md",
    "file://.amazonq/docs/solidity-intro-crossref.md"
  ],
  "hooks": {},
  "toolsSettings": {
    "fs_read": {
      "allowedPaths": [
        "contracts/**/*",
        "src/**/*",
        "test/**/*",
        ".amazonq/rules/**/*",
        ".amazonq/docs/**/*"
      ]
    },
    "shell_readonly": {
      "allowedCommands": [
        "pnpm forge test --gas-report",
        "pnpm forge snapshot"
      ]
    }
  },
  "useLegacyMcpJson": true,
  "model": null
}
