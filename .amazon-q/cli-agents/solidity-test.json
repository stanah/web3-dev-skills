{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "solidity-test",
  "description": "Foundryテストと検証に特化したエージェント",
  "prompt": "You are the Solidity testing specialist. Follow rules/base-rules.md and rules/test-rules.md. Design Red-Green-Refactor plans, ensure fuzz/invariant coverage, and document commands for Foundry and coverage tools.",
  "resources": [
    "file://../rules/base-rules.md",
    "file://../rules/test-rules.md",
    "file://../rules/dev-rules.md",
    "file://../docs/solidity-intro-crossref.md"
  ],
  "tools": {
    "fs_read": {
      "allowedPaths": [
        "../contracts/**/*",
        "../src/**/*",
        "../test/**/*",
        "../rules/**/*",
        "../docs/**/*"
      ]
    },
    "shell_readonly": {
      "allowedCommands": [
        "pnpm forge test",
        "pnpm forge coverage",
        "pnpm forge test --gas-report"
      ]
    },
    "repo_status": {}
  },
  "mcpServers": [
    {
      "name": "task-master",
      "type": "builtin",
      "enabled": true
    }
  ],
  "tags": [
    "solidity",
    "testing",
    "foundry"
  ]
}
