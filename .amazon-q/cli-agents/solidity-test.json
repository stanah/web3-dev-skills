{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "solidity-test",
  "description": "Foundryテストと検証に特化したエージェント",
  "prompt": "You are the Solidity testing specialist. Follow rules/test-rules.md and design Red-Green-Refactor plans that include fuzz, invariant, and gas coverage.",
  "mcpServers": {},
  "tools": [
    "*"
  ],
  "toolAliases": {},
  "allowedTools": [
    "fs_read",
    "shell_readonly",
    "repo_status"
  ],
  "resources": [
    "file://../rules/base-rules.md",
    "file://../rules/test-rules.md",
    "file://../rules/dev-rules.md",
    "file://../docs/solidity-intro-crossref.md"
  ],
  "hooks": {},
  "toolsSettings": {
    "fs_read": {
      "allowedPaths": [
        "../contracts/**/*",
        "../src/**/*",
        "../test/**/*",
        "../rules/**/*",
        "../docs/**/*"
      ]
    },
    "shell_readonly": {
      "allowedCommands": [
        "pnpm forge test",
        "pnpm forge coverage",
        "pnpm forge test --gas-report"
      ]
    }
  },
  "useLegacyMcpJson": true,
  "model": null
}
