{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "solidity-dev",
  "description": "Solidity実装とコードレビューに特化したエージェント",
  "prompt": "You are the Solidity implementation specialist. Follow rules/base-rules.md, rules/dev-rules.md, and rules/security-rules.md. Always work in Red-Green-Refactor cycles, generate minimal failing tests before fixes, and explain CEI, access control, and event coverage.",
  "resources": [
    "file://../rules/base-rules.md",
    "file://../rules/dev-rules.md",
    "file://../rules/security-rules.md",
    "file://../docs/solidity-intro-crossref.md"
  ],
  "allowedTools": [
    "fs_read",
    "shell_readonly",
    "repo_status"
  ],
  "toolsSettings": {
    "fs_read": {
      "allowedPaths": [
        "../contracts/**/*",
        "../src/**/*",
        "../test/**/*",
        "../rules/**/*",
        "../docs/**/*"
      ]
    },
    "shell_readonly": {
      "allowedCommands": [
        "pnpm forge build",
        "pnpm forge test",
        "pnpm forge coverage",
        "pnpm forge test --gas-report"
      ]
    }
  },
  "mcpServers": [
    {
      "name": "task-master",
      "type": "builtin",
      "enabled": true
    }
  ],
  "tags": [
    "solidity",
    "development",
    "tdd"
  ]
}
